{
  "name": "@itwin/appui-react",
  "version": "5.28.0",
  "description": "A react component library for AppUI framework",
  "type": "module",
  "types": "./lib/appui-react.d.ts",
  "exports": {
    ".": "./lib/appui-react.js",
    "./package.json": "./package.json",
    "./lib/cjs/*": {
      "sass": "./lib/*"
    },
    "./lib/esm/*": {
      "sass": "./lib/*"
    },
    "./*": {
      "sass": "./*"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iTwin/appui.git",
    "directory": "ui/appui-react"
  },
  "scripts": {
    "dev": "pnpm \"/^dev:.*/\"",
    "dev:css": "pnpm build:css -w",
    "dev:locale": "pnpm build:locale -w",
    "dev:tsc": "tsc -w --preserveWatchOutput",
    "build": "pnpm \"/^build:.*/\"",
    "build:compat:cjs": "cpx \"./src/**/*.{*css,svg}\" ./lib/cjs",
    "build:compat:esm": "cpx \"./src/**/*.{*css,svg}\" ./lib/esm",
    "build:locale": "cpx ./src/appui-react/UiFramework.json ./lib/public/locales/en",
    "build:css": "cpx \"./src/**/*.{*css,json,svg}\" ./lib",
    "build:tsc": "tsc",
    "clean": "rimraf -g lib",
    "cover": "vitest run --coverage",
    "lint": "eslint \"./src/**/*.{ts,tsx}\"",
    "lint:fix": "pnpm lint --fix",
    "extract-api": "betools extract-api --entry=./lib/appui-react --apiReportFolder=../../common/api --apiReportTempFolder=../../common/temp/api --apiSummaryFolder=../../common/api/summary",
    "test": "vitest",
    "docs": "pnpm \"/^docs:.*/\"",
    "docs:changelog": "cpx ./CHANGELOG.md ../../generated-docs/reference/appui-react",
    "docs:reference": "cross-env NODE_PROJECT_ROOT_DIRECTORY=../../ betools docs --includes=../../generated-docs/extract --json=../../generated-docs/reference/appui-react/file.json --tsIndexFile=./appui-react.ts --onlyJson",
    "docs:extract": "betools extract --fileExt=ts,tsx --extractFrom=./src/test --recursive --out=../../generated-docs/extract"
  },
  "keywords": [
    "AppUI",
    "Bentley",
    "BIM",
    "iModel"
  ],
  "author": {
    "name": "Bentley Systems, Inc.",
    "url": "http://www.bentley.com"
  },
  "peerDependencies": {
    "@itwin/appui-abstract": "^4.0.0 || ^5.0.0",
    "@itwin/components-react": "workspace:*",
    "@itwin/core-bentley": "^4.0.0 || ^5.0.0",
    "@itwin/core-common": "^4.0.0 || ^5.0.0",
    "@itwin/core-frontend": "^4.0.0 || ^5.0.0",
    "@itwin/core-geometry": "^4.0.0 || ^5.0.0",
    "@itwin/core-quantity": "^4.0.0 || ^5.0.0",
    "@itwin/core-react": "workspace:*",
    "@itwin/imodel-components-react": "workspace:*",
    "@itwin/itwinui-react": "^3.15.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-redux": "^7.2.2 || ^8.0.0 || ^9.0.0",
    "redux": "^4.1.0 || ^5.0.0"
  },
  "devDependencies": {
    "@itwin/appui-abstract": "catalog:",
    "@itwin/build-tools": "catalog:",
    "@itwin/components-react": "workspace:*",
    "@itwin/core-bentley": "catalog:",
    "@itwin/core-common": "catalog:",
    "@itwin/core-frontend": "catalog:",
    "@itwin/core-geometry": "catalog:",
    "@itwin/core-orbitgt": "catalog:",
    "@itwin/core-quantity": "catalog:",
    "@itwin/core-react": "workspace:*",
    "@itwin/ecschema-metadata": "catalog:",
    "@itwin/eslint-plugin": "catalog:",
    "@itwin/imodel-components-react": "workspace:*",
    "@itwin/itwinui-react": "catalog:",
    "@itwin/webgl-compatibility": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-transition-group": "^4.4.12",
    "@vitest/coverage-v8": "^3.2.4",
    "cpx2": "^3.0.2",
    "cross-env": "^5.2.1",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "ignore-styles": "^5.0.1",
    "inversify": "^7.11.0",
    "jsdom": "^24.1.3",
    "npm-run-all": "^4.1.5",
    "raf": "^3.4.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "reflect-metadata": "^0.2.2",
    "rimraf": "catalog:",
    "typemoq": "^2.1.0",
    "typescript": "~5.6.3",
    "upath": "^2.0.1",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@itwin/itwinui-icons-react": "^2.11.0",
    "@itwin/itwinui-illustrations-react": "^2.1.0",
    "classnames": "2.5.1",
    "immer": "^10.2.0",
    "lodash": "catalog:",
    "react-error-boundary": "^5.0.0",
    "react-transition-group": "^4.4.5",
    "rxjs": "^7.8.2",
    "ts-key-enum": "~2.0.13",
    "zustand": "catalog:"
  }
}
