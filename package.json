{
  "name": "appui",
  "private": true,
  "description": "Monorepo for iTwin.js AppUI",
  "license": "MIT",
  "scripts": {
    "dev": "run-p dev:packages storybook",
    "dev:packages": "pnpm --recursive --parallel --filter=!test-app --filter=!appui-storybook dev",
    "app": "pnpm --filter=test-app dev",
    "storybook": "pnpm --filter=appui-storybook dev",
    "build": "pnpm --recursive build",
    "clean": "pnpm --recursive --parallel clean",
    "docs": "pnpm --recursive --parallel docs",
    "lint": "pnpm --recursive --parallel lint",
    "lint:copyright": "pnpm exec tsx common/scripts/copyright-linter.ts",
    "test": "pnpm --recursive --parallel test",
    "cover": "pnpm --recursive --parallel cover",
    "extract-api": "pnpm --recursive --parallel extract-api",
    "cspell": "pnpm exec cspell lint \"**\" --gitignore",
    "prettier": "pnpm exec prettier --check .",
    "prettier:fix": "pnpm exec prettier --write .",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.6",
    "cspell": "^8.19.4",
    "fast-glob": "^3.3.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.8",
    "tsx": "^4.21.0"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=24.11.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iTwin/appui"
  },
  "author": {
    "name": "Bentley Systems, Inc.",
    "url": "http://www.bentley.com"
  },
  "pnpm": {
    "overrides": {
      "mocha>diff@7.0.0": "^8.0.3",
      "mocha>serialize-javascript@^6.0.0": "^7.0.4",
      "@microsoft/api-extractor>lodash@4.17": "~4.18.0",
      "@google-cloud/storage>retry-request@7": "8",
      "@google-cloud/storage>teeny-request@9": "10",
      "uuid@<14.0.0": "^14.0.0",
      "postcss@<8.5.10": ">=8.5.10",
      "axios@>=1.0.0 <1.15.2": ">=1.15.2"
    }
  }
}
