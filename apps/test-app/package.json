{
  "name": "test-app",
  "type": "module",
  "description": "AppUI Test Application",
  "private": true,
  "license": "MIT",
  "version": "0.0.0",
  "homepage": "http://localhost:3000/",
  "scripts": {
    "dev": "pnpm prebuild:frontend && run-p dev:*",
    "dev:webserver": "vite",
    "dev:backend": "node --max-http-header-size=16000 lib/backend/main.js",
    "dev:tsc:backend": "pnpm build:backend -w --preserveWatchOutput",
    "electron": "run-p dev:webserver electron:start",
    "build": "pnpm \"/^build:.*/\"",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:frontend": "vite build",
    "prebuild:backend": "node ./scripts/package-cjs.js ./lib",
    "prebuild:frontend": "pnpm --aggregate-output \"/^frontend:.*/\"",
    "frontend:webfont": "copyfiles -f ./node_modules/@bentley/icons-generic-webfont/dist/**/* ./lib/webfont",
    "frontend:pseudolocalize": "betools pseudolocalize --englishDir ./lib/locales/en --out ./lib/locales/en-PSEUDO",
    "prefrontend:pseudolocalize": "copyfiles -f ./node_modules/@itwin/*/lib/public/locales/en/*.json ./public/locales/en/*.json ./lib/locales/en",
    "preview": "vite preview --port 3000",
    "clean": "rimraf -g lib build dist",
    "lint": "eslint \"./src/**/*.{ts,tsx}\"",
    "electron:start": "cross-env NODE_ENV=development electron ./lib/backend/main.js",
    "docs": "betools extract --fileExt=ts,tsx --extractFrom=./src --recursive --out=../../../generated-docs/extract"
  },
  "keywords": [
    "Bentley",
    "BIM",
    "iModel"
  ],
  "author": {
    "name": "Bentley Systems, Inc.",
    "url": "http://www.bentley.com"
  },
